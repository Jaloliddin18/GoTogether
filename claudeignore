# .claudeignore — tells Claude Code what to skip reading
# This keeps context lean and prevents Claude Code from wasting tokens
# on irrelevant legacy code or generated files.

# ── Dependencies ──────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────
dist/
build/
.next/

# ── Batch app (separate concern — do not read unless asked) ───────
apps/nestar-batch/

# ── Legacy real-estate modules (being phased out — do not read) ───
# These exist but are not part of Smart Library work.
# Claude Code must not reference or modify these.
apps/nestar-api/src/components/property/
apps/nestar-api/src/components/agent/
apps/nestar-api/src/schemas/Property.model.ts
apps/nestar-api/src/schemas/Agent.model.ts

# ── Runtime uploads (not code) ────────────────────────────────────
uploads/

# ── Test snapshots and coverage ───────────────────────────────────
coverage/
__snapshots__/

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/

# ── Environment files (secrets) ───────────────────────────────────
.env
.env.*

# ── Editor and OS noise ───────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.suo
*.user
